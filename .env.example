# Telegram Bot API token — get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram chat ID — send /start to your bot, then check getUpdates
TELEGRAM_CHAT_ID=your_chat_id_here

# Note: These are set as Convex environment variables, NOT local .env
# Set them via: npx convex env set TELEGRAM_BOT_TOKEN <value>
# Or via the Convex dashboard: https://dashboard.convex.dev
